#variable {gstin[colors][highlight][experience]}      {$gstin[palette][bright_green]}
#variable {gstin[colors][highlight][player_disk]}     {$gstin[palette][sky_blue]}
#variable {gstin[colors][highlight][player_title]}    {$gstin[palette][cornflower]}
#variable {gstin[colors][highlight][player_name]}     {$gstin[palette][sky_blue]}
#variable {gstin[colors][highlight][player_status]}   {$gstin[palette][orange]}
#variable {gstin[colors][highlight][creature]}        {$gstin[palette][dark_blue]}
