#nop =========================================================================;
#nop  GSTinTin - Macros and Key Bindings
#nop  Numpad directions, combat shortcuts, and utility commands.
#nop =========================================================================;

#class {gstin_macros} {open}

#nop ---- Mouse support --;
#nop -- Enables xterm mouse tracking so wheel/click events reach tt++. --;
#nop -- Without this, mouse wheel gets interpreted by the terminal as arrow --;
#nop -- keys which move the input line cursor (useless). --;
#config {mouse tracking} {on};

#nop -- Hit-test the cursor row/col against known regions. --;
#nop -- Sets gstin[_hit] to: story|chat|familiar|spells|other. --;
#nop -- Story is rows top_size+1 to bar_bot, cols left_w+1 to right_col-1 (or cols). --;
#nop -- Chat is rows bar_top to bar_bot-9, cols 1 to left_w-1. --;
#nop -- Familiar is rows 6 to top_size-1 when active, cols 1 to cols. --;
#alias {gstin_mouse_hit_test} {
    #local {_row} {%1};
    #local {_col} {%2};
    #variable {gstin[_hit]} {other};
    #nop -- Familiar panel (inside top pane, rows 6 through top_size-1) --;
    #if {$gstin[familiar][active] == 1 && $_row >= 6 && $_row < $gstin[ui][top_size]} {
        #variable {gstin[_hit]} {familiar};
        #return;
    };
    #nop -- Chat sidebar (left column, below top pane, above bottom bars) --;
    #if {$_col < $gstin[ui][left_w] && $_row >= $gstin[ui][bar_top] && $_row <= $gstin[ui][bar_bot] - 9} {
        #variable {gstin[_hit]} {chat};
        #return;
    };
    #nop -- Spells sidebar (right column when active) --;
    #if {$gstin[ui][right_active] == 1 && $_col >= $gstin[ui][right_col] && $_row >= $gstin[ui][bar_top] && $_row <= $gstin[ui][bar_bot]} {
        #variable {gstin[_hit]} {spells};
        #return;
    };
    #nop -- Story scroll region (middle column, main scrollback) --;
    #if {$_col >= $gstin[ui][left_w] && $_row > $gstin[ui][top_size] && $_row <= $gstin[ui][bar_bot]} {
        #variable {gstin[_hit]} {story};
        #return;
    };
}

#nop -- Wheel up: route to whatever window is under the cursor --;
#nop -- Story uses #buffer up N (default is full page, we want 2-line steps). --;
#nop -- We maintain gstin[_story_scroll] as a tin-side counter matching how far --;
#nop -- the user has wheeled back, so the [Story +N] header indicator works. --;
#nop -- Header renders in gstin_render_chat, mark chat dirty to trigger redraw. --;
#event {SCROLLED MOUSE WHEEL UP} {
    gstin_mouse_hit_test {%0} {%1};
    #switch {"$gstin[_hit]"} {
        #case {"chat"} {gstin_chat_scroll_line_up};
        #case {"familiar"} {gstin_familiar_scroll_line_up};
        #case {"story"} {gstin_story_scroll_up};
    };
}

#nop ---- Split drag resize -----------------------------------------------;
#nop -- Clamp a candidate top_size into a safe range. Keep at least 3 rows --;
#nop -- for the scrolling region and one row of bottom bar + input. --;
#alias {gstin_clamp_top_size} {
    #local {_v} {%1};
    #local {_max} {0};
    #math {_max} {$gstin[ui][rows] - 4};
    #if {$_max < 3} {#local {_max} {3}};
    #if {$_v < 3}    {#local {_v} {3}};
    #if {$_v > $_max} {#local {_v} {$_max}};
    #variable {gstin[_resize][clamped]} {$_v};
}

#nop -- Clamp a candidate left pane width. Respect chat_min_width (hard min --;
#nop -- 31 for vitals/status) and leave >=10 cols for center scroll. --;
#alias {gstin_clamp_left_w} {
    #local {_v} {%1};
    #local {_min} {$gstin[config][chat_min_width]};
    #if {$_min < 31} {#local {_min} {31}};
    #local {_max} {0};
    #math {_max} {$gstin[ui][cols] - $gstin[ui][right_w] - 10};
    #if {$_max < $_min} {#local {_max} {$_min}};
    #if {$_v < $_min} {#local {_v} {$_min}};
    #if {$_v > $_max} {#local {_v} {$_max}};
    #variable {gstin[_resize][clamped]} {$_v};
}

#nop -- Clamp a candidate right pane width. Min 10 so effect bars fit, and --;
#nop -- leave >=10 cols for center scroll after accounting for left pane. --;
#alias {gstin_clamp_right_w} {
    #local {_v} {%1};
    #local {_min} {10};
    #local {_max} {0};
    #math {_max} {$gstin[ui][cols] - $gstin[ui][left_w] - 10};
    #if {$_max < $_min} {#local {_max} {$_min}};
    #if {$_v < $_min} {#local {_v} {$_min}};
    #if {$_v > $_max} {#local {_v} {$_max}};
    #variable {gstin[_resize][clamped]} {$_v};
}

#nop -- Common post-resize housekeeping: invalidate snapshot caches so every --;
#nop -- piece of chrome (room box, vitals header, sidebar bars) gets rebuilt --;
#nop -- at the new geometry, then request a coalesced full render. --;
#alias {gstin_resize_invalidate} {
    #variable {gstin[_split_needed]} {1};
    #variable {gstin[_prev_rbar]} {};
    #variable {gstin[_prev][header]}     {0};
    #variable {gstin[_prev][body]}       {_};
    #variable {gstin[_prev][vitals]}     {_};
    #variable {gstin[_prev][mind]}       {_};
    #variable {gstin[_prev][enc]}        {_};
    #variable {gstin[_prev][conditions]} {_};
    #variable {gstin[_prev][spell]}      {_};
    #variable {gstin[_prev][hands]}      {_};
    #variable {gstin[_prev][bottom]}     {_};
    #variable {gstin[_prev][chat]}       {_};
    #variable {gstin[_chat_dirty]} {1};
    gstin_dirty_all;
    gstin_request_render;
}

#nop -- Apply a new top_size from a drag. Only runs when the cursor row --;
#nop -- differs from the last applied row, so in-row mouse jitter is free. --;
#alias {gstin_apply_drag_top_size} {
    #local {_row} {%1};
    gstin_clamp_top_size {$_row};
    #local {_new} {$gstin[_resize][clamped]};
    #if {$_new != $gstin[ui][top_size]} {
        #variable {gstin[ui][user_top_size]} {$_new};
        #variable {gstin[_resize_needed]} {$_new};
        gstin_resize_invalidate;
    };
    #variable {gstin[_resize][last_row]} {$_row};
}

#nop -- Apply a new left_w from a drag. Cursor column is the target width --;
#nop -- (left pane spans cols 1..left_w). Chat buffer is rewrapped by --;
#nop -- gstin_apply_resize's existing #split path. --;
#alias {gstin_apply_drag_left_w} {
    #local {_col} {%1};
    gstin_clamp_left_w {$_col};
    #local {_new} {$gstin[_resize][clamped]};
    #if {$_new != $gstin[ui][left_w]} {
        #variable {gstin[ui][user_left_w]} {$_new};
        #variable {gstin[ui][left_w]} {$_new};
        gstin_resize_invalidate;
    };
    #variable {gstin[_resize][last_col]} {$_col};
}

#nop -- Apply a new room/familiar ratio from a drag on the familiar separator. --;
#nop -- Cursor row is the would-be fam_sep position, so room_rows = row - 2 --;
#nop -- (rows 2..row-1 = room content, row = separator). Content rows are --;
#nop -- (top_size - 2 - 1) = top_size-3 with familiar active. Room must keep --;
#nop -- >=3 contentful rows, familiar >=1. Ratio stored as percent so a later --;
#nop -- top_size change resizes both panes proportionally. --;
#alias {gstin_apply_drag_fam} {
    #local {_row} {%1};
    #if {$gstin[familiar][active] == 0} {#return};
    #local {_inner} {0};
    #math {_inner} {$gstin[ui][top_size] - 2};
    #local {_content} {0};
    #math {_content} {$_inner - 1};
    #if {$_content < 4} {#local {_content} {4}};
    #local {_rrows} {0};
    #math {_rrows} {$_row - 2};
    #if {$_rrows < 3} {#local {_rrows} {3}};
    #local {_max_rrows} {0};
    #math {_max_rrows} {$_content - 1};
    #if {$_rrows > $_max_rrows} {#local {_rrows} {$_max_rrows}};
    #local {_pct} {0};
    #math {_pct} {($_rrows * 100 + $_content / 2) / $_content};
    #if {$_pct < 1}  {#local {_pct} {1}};
    #if {$_pct > 99} {#local {_pct} {99}};
    #if {$_pct != $gstin[ui][user_room_pct]} {
        #variable {gstin[ui][user_room_pct]} {$_pct};
        gstin_resize_invalidate;
    };
    #variable {gstin[_resize][last_row]} {$_row};
}

#nop -- Apply a new right_w from a drag. Cursor column defines the left --;
#nop -- edge of the right pane, so right_w = cols - col + 1. --;
#alias {gstin_apply_drag_right_w} {
    #local {_col} {%1};
    #local {_want} {0};
    #math {_want} {$gstin[ui][cols] - $_col + 1};
    gstin_clamp_right_w {$_want};
    #local {_new} {$gstin[_resize][clamped]};
    #if {$_new != $gstin[ui][right_w]} {
        #variable {gstin[ui][user_right_w]} {$_new};
        #variable {gstin[ui][right_w]} {$_new};
        #math {gstin[ui][right_col]} {$gstin[ui][cols] - $_new + 1};
        gstin_resize_invalidate;
    };
    #variable {gstin[_resize][last_col]} {$_col};
}

#nop -- Press arms a drag mode based on where the cursor is. --;
#nop --   * separator row (top_size)           -> top drag --;
#nop --   * familiar separator (fam_sep)       -> familiar drag --;
#nop --   * col left_w within bar_top..bar_bot -> left drag --;
#nop --   * col right_col (if right_active)    -> right drag --;
#nop --   * [More...] marker row               -> expand top pane --;
#event {PRESSED MOUSE BUTTON ONE} {
    #local {_r} {%0};
    #local {_c} {%1};
    #if {$gstin[_resize][active] == 1} {#return};
    #if {$_r == $gstin[ui][top_size]} {
        #variable {gstin[_resize][active]} {1};
        #variable {gstin[_resize][axis]} {top};
        #variable {gstin[_resize][last_row]} {$_r};
        gstin_redraw_bottom_border;
        #return;
    };
    #if {$gstin[familiar][active] == 1 && $gstin[ui][fam_sep] > 0 && $_r == $gstin[ui][fam_sep]} {
        #variable {gstin[_resize][active]} {1};
        #variable {gstin[_resize][axis]} {familiar};
        #variable {gstin[_resize][last_row]} {$_r};
        gstin_redraw_fam_separator;
        #return;
    };
    #if {$_r >= $gstin[ui][bar_top] && $_r <= $gstin[ui][bar_bot] && $_c == $gstin[ui][left_w]} {
        #variable {gstin[_resize][active]} {1};
        #variable {gstin[_resize][axis]} {left};
        #variable {gstin[_resize][last_col]} {$_c};
        gstin_redraw_left_bar;
        #return;
    };
    #if {$gstin[ui][right_active] == 1 && $_r >= $gstin[ui][bar_top] && $_r <= $gstin[ui][bar_bot] && $_c == $gstin[ui][right_col]} {
        #variable {gstin[_resize][active]} {1};
        #variable {gstin[_resize][axis]} {right};
        #variable {gstin[_resize][last_col]} {$_c};
        gstin_redraw_right_bar;
        #return;
    };
    #if {&gstin[_more_row][$_r]} {
        gstin_expand_for_more;
    };
}

#nop -- Grow the top pane so every [More...] section can show all its lines. --;
#nop -- Sum the "extra rows needed" values recorded by gstin_draw_section_with_more, --;
#nop -- bump user_top_size by that total (clamped to terminal height), then --;
#nop -- kick a full re-render. --;
#alias {gstin_expand_for_more} {
    #local {_extra} {0};
    #foreach {$gstin[_more_row][%*]} {_need} {
        #math {_extra} {$_extra + $_need};
    };
    #if {$_extra < 1} {#return};
    #nop -- Familiar active: room gets only pct% of content growth, so scale --;
    #nop -- the requested room delta up by 100/pct. Effective pct comes from --;
    #nop -- current row_end placement so a user-dragged ratio is honored. --;
    #if {$gstin[familiar][active] == 1} {
        gstin_calc_pane_rows;
        #local {_inner} {0};
        #math {_inner} {$gstin[ui][top_size] - 2};
        #local {_content} {0};
        #math {_content} {$_inner - 1};
        #if {$_content < 4} {#local {_content} {4}};
        #local {_rrows} {0};
        #math {_rrows} {$gstin[ui][room_end] - 1};
        #if {$_rrows < 1} {#local {_rrows} {1}};
        #nop -- extra_top = ceil(need * content / rrows) --;
        #math {_extra} {($_extra * $_content + $_rrows - 1) / $_rrows};
    };
    #local {_new} {0};
    #math {_new} {$gstin[ui][top_size] + $_extra};
    gstin_clamp_top_size {$_new};
    #local {_clamped} {$gstin[_resize][clamped]};
    #if {$_clamped == $gstin[ui][top_size]} {#return};
    #variable {gstin[ui][user_top_size]} {$_clamped};
    #variable {gstin[_resize_needed]} {$_clamped};
    gstin_resize_invalidate;
}

#nop -- Drag: only relayout when the cursor crosses a boundary. Rapid moves --;
#nop -- coalesce via gstin_request_render's #delay 0. Dispatch by axis. --;
#event {MOVED MOUSE BUTTON ONE} {
    #local {_r} {%0};
    #local {_c} {%1};
    #if {$gstin[_resize][active] != 1} {#return};
    #switch {"$gstin[_resize][axis]"} {
        #case {"top"} {
            #if {$_r != $gstin[_resize][last_row]} {
                gstin_apply_drag_top_size {$_r};
            };
        };
        #case {"familiar"} {
            #if {$_r != $gstin[_resize][last_row]} {
                gstin_apply_drag_fam {$_r};
            };
        };
        #case {"left"} {
            #if {$_c != $gstin[_resize][last_col]} {
                gstin_apply_drag_left_w {$_c};
            };
        };
        #case {"right"} {
            #if {$_c != $gstin[_resize][last_col]} {
                gstin_apply_drag_right_w {$_c};
            };
        };
    };
}

#nop -- Release clears resize mode and forces a clean full-chrome repaint. --;
#nop -- Mid-drag renders coalesce through #delay 0 and can leave the top --;
#nop -- border, side-sidebar borders, and section headers stale. Doing a --;
#nop -- final force-redraw here rebuilds all chrome at the settled size. --;
#event {RELEASED MOUSE BUTTON ONE} {
    #if {$gstin[_resize][active] == 1} {
        #variable {gstin[_resize][active]} {0};
        #variable {gstin[_resize][axis]} {};
        gstin_resize_invalidate;
        #nop -- Extra deferred top-border repaint: row 1 #showme is fragile --;
        #nop -- right after a #split (per CLAUDE.md gotcha #8). One more pass --;
        #nop -- after everything settles guarantees the corners. Do NOT repaint --;
        #nop -- the bottom border here -- it shares its row with the Feed/Story --;
        #nop -- headers drawn by gstin_render_chat, and a late ── would erase them. --;
        #delay {gstin_resize_finish} {gstin_redraw_top_border} {0.1};
    };
}

#event {SCROLLED MOUSE WHEEL DOWN} {
    gstin_mouse_hit_test {%0} {%1};
    #switch {"$gstin[_hit]"} {
        #case {"chat"} {gstin_chat_scroll_line_down};
        #case {"familiar"} {gstin_familiar_scroll_line_down};
        #case {"story"} {gstin_story_scroll_down};
    };
}

#nop -- Read tt++ scrollback offset into gstin[_story_scroll]. LINE == -1 means --;
#nop -- live (at bottom), otherwise scrolled-back distance = USED - 1 - LINE. --;
#alias {gstin_update_story_scroll} {
    #variable {gstin[_bi]} {};
    #buffer info save {gstin[_bi]};
    #if {$gstin[_bi][LINE] < 0} {
        #variable {gstin[_story_scroll]} {0};
    } {
        #math {gstin[_story_scroll]} {$gstin[_bi][USED] - 1 - $gstin[_bi][LINE]};
        #if {$gstin[_story_scroll] < 0} {#variable {gstin[_story_scroll]} {0}};
    };
}

#alias {gstin_story_scroll_up} {
    #buffer up 2;
    gstin_update_story_scroll;
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#alias {gstin_story_scroll_down} {
    #buffer down 2;
    gstin_update_story_scroll;
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#nop -- Full-page scroll for the main story buffer. Step is bar_bot-bar_top, --;
#nop -- i.e. the height of the visible scroll region. --;
#alias {gstin_story_page_up} {
    #local {_n} {0};
    #math {_n} {$gstin[ui][bar_bot] - $gstin[ui][bar_top] + 1};
    #if {$_n < 1} {#local {_n} {1}};
    #buffer up $_n;
    gstin_update_story_scroll;
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#alias {gstin_story_page_down} {
    #local {_n} {0};
    #math {_n} {$gstin[ui][bar_bot] - $gstin[ui][bar_top] + 1};
    #if {$_n < 1} {#local {_n} {1}};
    #buffer down $_n;
    gstin_update_story_scroll;
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#nop -- Jump to the oldest/newest line in the main scrollback. Home parks --;
#nop -- at the top of the buffer, End returns to live. --;
#alias {gstin_story_scroll_top} {
    #buffer home;
    gstin_update_story_scroll;
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#alias {gstin_story_scroll_bottom} {
    #buffer end;
    gstin_update_story_scroll;
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#nop -- When a new line arrives in scrollback while the user is scrolled back, --;
#nop -- the offset grows by 1. Refresh the [Story +N] header to reflect it. --;
#nop -- Only fires when already scrolled, so no overhead in the live case. --;
#nop -- Scrollback grew (mud line OR #showme). Refresh [Story +N] header if --;
#nop -- the user is scrolled back. BUFFER UPDATE fires for both server lines --;
#nop -- and #showme output, unlike PROCESSED LINE which misses gagged+showme'd --;
#nop -- text (which is most of our display). --;
#event {BUFFER UPDATE} {
    #if {$gstin[_story_scroll] > 0} {
        gstin_update_story_scroll;
        #variable {gstin[_chat_dirty]} {1};
        #variable {gstin[_dirty][chat]} {1};
        gstin_request_render;
    };
}

#nop ---- Numpad directional macros (matching ProfanityFE layout) --;
#macro {\eOq} {sw\n}
#macro {\eOr} {s\n}
#macro {\eOs} {se\n}
#macro {\eOt} {w\n}
#macro {\eOu} {out\n}
#macro {\eOv} {e\n}
#macro {\eOw} {nw\n}
#macro {\eOx} {n\n}
#macro {\eOy} {ne\n}

#nop -- Numpad + for look --;
#macro {\eOk} {look\n}
#nop -- Numpad - for up --;
#macro {\eOm} {up\n}
#nop -- Numpad * for down --;
#macro {\eOj} {down\n}

#nop ---- Chat scroll macros --;
#nop -- Ctrl+PageUp/Down: half-page chat scroll --;
#macro {\e[5;5~} {gstin_chat_scroll_up};
#macro {\e[6;5~} {gstin_chat_scroll_down};
#nop -- Ctrl+Up/Down: single-line chat scroll --;
#macro {\e[1;5A} {gstin_chat_scroll_line_up};
#macro {\e[1;5B} {gstin_chat_scroll_line_down};
#nop -- Shift+PageUp/Down: half-page familiar scroll --;
#macro {\e[5;2~} {gstin_familiar_scroll_up};
#macro {\e[6;2~} {gstin_familiar_scroll_down};
#nop -- Shift+Up/Down: single-line familiar scroll --;
#macro {\e[1;2A} {gstin_familiar_scroll_line_up};
#macro {\e[1;2B} {gstin_familiar_scroll_line_down};
#nop -- Home/End: jump to top/bottom of main story scrollback. xterm emits --;
#nop -- \e[H / \e[F or \eOH / \eOF depending on keypad mode -- bind both. --;
#macro {\e[H} {gstin_story_scroll_top};
#macro {\e[F} {gstin_story_scroll_bottom};
#macro {\eOH} {gstin_story_scroll_top};
#macro {\eOF} {gstin_story_scroll_bottom};
#macro {\e[1~} {gstin_story_scroll_top};
#macro {\e[4~} {gstin_story_scroll_bottom};
#macro {\e[7~} {gstin_story_scroll_top};
#macro {\e[8~} {gstin_story_scroll_bottom};
#nop -- Emacs-style story scroll: C-v page down, M-v page up, M-< top, M-> bottom --;
#macro {\x16} {gstin_story_page_down};
#macro {\ev}  {gstin_story_page_up};
#macro {\e<}  {gstin_story_scroll_top};
#macro {\e>}  {gstin_story_scroll_bottom};
#nop -- Ctrl+Home/End: jump to top/bottom of chat feed --;
#macro {\e[1;5H} {gstin_chat_scroll_top};
#macro {\e[1;5F} {gstin_chat_scroll_bottom};
#macro {\e[7;5~} {gstin_chat_scroll_top};
#macro {\e[8;5~} {gstin_chat_scroll_bottom};
#nop -- Shift+Home/End: jump to top/bottom of familiar feed --;
#macro {\e[1;2H} {gstin_familiar_scroll_top};
#macro {\e[1;2F} {gstin_familiar_scroll_bottom};
#macro {\e[7;2~} {gstin_familiar_scroll_top};
#macro {\e[8;2~} {gstin_familiar_scroll_bottom};

#nop -- Half the chat window row count. Stored in gstin[_chat_page_size] so --;
#nop -- callers can read it. Could be replaced with a config var later. --;
#alias {gstin_chat_page_size} {
    #math {gstin[_chat_page_size]} {($gstin[ui][bar_bot] - 9 - $gstin[ui][bar_top] + 1) / 2};
    #if {$gstin[_chat_page_size] < 1} {#variable {gstin[_chat_page_size]} {1}};
}

#nop -- Compute chat scroll ceiling (lines - visible rows). --;
#alias {gstin_chat_scroll_max} {
    #local {_sz} {0};
    #list {gstin[chat][lines]} {size} {_sz};
    #local {_visible} {0};
    #math {_visible} {$gstin[ui][bar_bot] - 9 - $gstin[ui][bar_top] + 1};
    #math {gstin[_chat_scroll_max]} {$_sz - $_visible};
    #if {$gstin[_chat_scroll_max] < 0} {#variable {gstin[_chat_scroll_max]} {0}};
}

#alias {gstin_chat_scroll_up} {
    gstin_chat_page_size;
    gstin_chat_scroll_max;
    #math {gstin[chat][scroll]} {$gstin[chat][scroll] + $gstin[_chat_page_size]};
    #if {$gstin[chat][scroll] > $gstin[_chat_scroll_max]} {
        #variable {gstin[chat][scroll]} {$gstin[_chat_scroll_max]};
    };
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#alias {gstin_chat_scroll_down} {
    #if {$gstin[chat][scroll] > 0} {
        gstin_chat_page_size;
        #math {gstin[chat][scroll]} {$gstin[chat][scroll] - $gstin[_chat_page_size]};
        #if {$gstin[chat][scroll] < 0} {
            #variable {gstin[chat][scroll]} {0};
        };
        #variable {gstin[_chat_dirty]} {1};
        #variable {gstin[_dirty][chat]} {1};
        gstin_request_render;
    };
}

#alias {gstin_chat_scroll_line_up} {
    gstin_chat_scroll_max;
    #math {gstin[chat][scroll]} {$gstin[chat][scroll] + 1};
    #if {$gstin[chat][scroll] > $gstin[_chat_scroll_max]} {
        #variable {gstin[chat][scroll]} {$gstin[_chat_scroll_max]};
    };
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#alias {gstin_chat_scroll_line_down} {
    #if {$gstin[chat][scroll] > 0} {
        #math {gstin[chat][scroll]} {$gstin[chat][scroll] - 1};
        #variable {gstin[_chat_dirty]} {1};
        #variable {gstin[_dirty][chat]} {1};
        gstin_request_render;
    };
}

#nop -- Jump to oldest/newest line in the chat feed. Top snaps to the --;
#nop -- max scroll offset, bottom pins live at offset 0. --;
#alias {gstin_chat_scroll_top} {
    gstin_chat_scroll_max;
    #variable {gstin[chat][scroll]} {$gstin[_chat_scroll_max]};
    #variable {gstin[_chat_dirty]} {1};
    #variable {gstin[_dirty][chat]} {1};
    gstin_request_render;
}

#alias {gstin_chat_scroll_bottom} {
    #if {$gstin[chat][scroll] > 0} {
        #variable {gstin[chat][scroll]} {0};
        #variable {gstin[_chat_dirty]} {1};
        #variable {gstin[_dirty][chat]} {1};
        gstin_request_render;
    };
}

#nop -- Familiar visible-row count. Proportional split means the value --;
#nop -- changes with top_size, so read it from fam_sep/top_size. --;
#alias {gstin_familiar_visible_rows} {
    #variable {gstin[_familiar_visible]} {0};
    #if {$gstin[familiar][active] == 1} {
        gstin_calc_pane_rows;
        #math {gstin[_familiar_visible]} {$gstin[ui][top_size] - $gstin[ui][fam_sep] - 1};
        #if {$gstin[_familiar_visible] < 1} {#variable {gstin[_familiar_visible]} {1}};
    };
}

#nop -- Half-page scroll step based on current visible rows. --;
#alias {gstin_familiar_page_size} {
    gstin_familiar_visible_rows;
    #math {gstin[_familiar_page_size]} {$gstin[_familiar_visible] / 2};
    #if {$gstin[_familiar_page_size] < 1} {#variable {gstin[_familiar_page_size]} {1}};
}

#nop -- Compute familiar scroll ceiling (lines - visible rows). Clamps --;
#nop -- scroll-up so you cannot scroll past the first line in the buffer. --;
#alias {gstin_familiar_scroll_max} {
    gstin_familiar_visible_rows;
    #local {_sz} {0};
    #list {gstin[familiar][lines]} {size} {_sz};
    #math {gstin[_familiar_scroll_max]} {$_sz - $gstin[_familiar_visible]};
    #if {$gstin[_familiar_scroll_max] < 0} {#variable {gstin[_familiar_scroll_max]} {0}};
}

#alias {gstin_familiar_scroll_up} {
    #if {$gstin[familiar][active] == 1} {
        gstin_familiar_page_size;
        gstin_familiar_scroll_max;
        #math {gstin[familiar][scroll]} {$gstin[familiar][scroll] + $gstin[_familiar_page_size]};
        #if {$gstin[familiar][scroll] > $gstin[_familiar_scroll_max]} {
            #variable {gstin[familiar][scroll]} {$gstin[_familiar_scroll_max]};
        };
        #variable {gstin[_dirty][familiar]} {1};
        gstin_request_render;
    };
}

#alias {gstin_familiar_scroll_down} {
    #if {$gstin[familiar][active] == 1 && $gstin[familiar][scroll] > 0} {
        gstin_familiar_page_size;
        #math {gstin[familiar][scroll]} {$gstin[familiar][scroll] - $gstin[_familiar_page_size]};
        #if {$gstin[familiar][scroll] < 0} {
            #variable {gstin[familiar][scroll]} {0};
        };
        #variable {gstin[_dirty][familiar]} {1};
        gstin_request_render;
    };
}

#alias {gstin_familiar_scroll_line_up} {
    #if {$gstin[familiar][active] == 1} {
        gstin_familiar_scroll_max;
        #math {gstin[familiar][scroll]} {$gstin[familiar][scroll] + 1};
        #if {$gstin[familiar][scroll] > $gstin[_familiar_scroll_max]} {
            #variable {gstin[familiar][scroll]} {$gstin[_familiar_scroll_max]};
        };
        #variable {gstin[_dirty][familiar]} {1};
        gstin_request_render;
    };
}

#alias {gstin_familiar_scroll_line_down} {
    #if {$gstin[familiar][active] == 1 && $gstin[familiar][scroll] > 0} {
        #math {gstin[familiar][scroll]} {$gstin[familiar][scroll] - 1};
        #variable {gstin[_dirty][familiar]} {1};
        gstin_request_render;
    };
}

#nop -- Jump to oldest/newest line in the familiar feed. --;
#alias {gstin_familiar_scroll_top} {
    #if {$gstin[familiar][active] == 1} {
        gstin_familiar_scroll_max;
        #variable {gstin[familiar][scroll]} {$gstin[_familiar_scroll_max]};
        #variable {gstin[_dirty][familiar]} {1};
        gstin_request_render;
    };
}

#alias {gstin_familiar_scroll_bottom} {
    #if {$gstin[familiar][active] == 1 && $gstin[familiar][scroll] > 0} {
        #variable {gstin[familiar][scroll]} {0};
        #variable {gstin[_dirty][familiar]} {1};
        gstin_request_render;
    };
}

#nop ---- Game command aliases ----;

#nop -- Quick stance switching --;
#alias {def} {stance defensive}
#alias {off} {stance offensive}

#nop -- Quick look at self --;
#alias {gs} {look at my self}

#nop -- Lich convenience --;
#alias {,%0} {#send {;%0}}

#nop ---- GSTinTin utility commands ----;

#nop -- Show current game state --;
#alias {gstin_state} {
    #showme {$gstin[colors][system][status]--- GSTinTin State ---<099>};
    #showme {HP: $gstin[vitals][health][current]/$gstin[vitals][health][max]  MN: $gstin[vitals][mana][current]/$gstin[vitals][mana][max]};
    #showme {ST: $gstin[vitals][stamina][current]/$gstin[vitals][stamina][max]  SP: $gstin[vitals][spirit][current]/$gstin[vitals][spirit][max]};
    #showme {Stance: $gstin[vitals][stance][value]  Mind: $gstin[vitals][mind][text]  Load: $gstin[vitals][encumbrance][text]};
    #showme {L: $gstin[hands][left]  R: $gstin[hands][right]  Spell: $gstin[spell]};
    #showme {Room: $gstin[room][title]};
    #showme {Prompt: $gstin[prompt][text]  TimeOffset: $gstin[time][offset]};
}

#nop -- Show experience --;
#alias {gstin_exp} {
    #showme {$gstin[colors][system][status]--- Experience ---<099>};
    #foreach {*gstin[exp][]} {_skill} {
        #showme {  $_skill: $gstin[exp][$_skill]};
    };
}

#nop -- Show injuries --;
#alias {gstin_injuries} {
    #showme {$gstin[colors][system][status]--- Injuries ---<099>};
    #foreach {*gstin[injuries][]} {_part} {
        #if {"$gstin[injuries][$_part]" != ""} {
            #showme {  $_part: $gstin[injuries][$_part]};
        };
    };
}

#nop -- Toggle compact mode (message spacing) --;
#alias {compact} {
    #math {gstin[config][compact]} {!$gstin[config][compact]};
    #if {$gstin[config][compact] == 1} {
        #showme {$gstin[colors][system][status]--- Compact mode: ON<099>};
    } {
        #showme {$gstin[colors][system][status]--- Compact mode: OFF<099>};
    };
}

#nop -- Reload theme: kill palette class, reload palette + semantic colors, refresh UI --;
#alias {gstin_load_theme} {
    #class {gstin_palette} {kill};
    #read {config/palette_$gstin[config][theme].tin};
    #if {"$gstin[palette][terminal_fg]" != ""} {
        #system {printf '\e]10;$gstin[palette][terminal_fg]\e\\'};
    };
    #if {"$gstin[palette][terminal_bg]" != ""} {
        #system {printf '\e]11;$gstin[palette][terminal_bg]\e\\'};
    };
    #if {"$gstin[palette][terminal_cursor]" != ""} {
        #system {printf '\e]12;$gstin[palette][terminal_cursor]\e\\'};
    };
    #class {gstin_colors} {kill};
    #read {config/colors.tin};
    #nop -- Re-read the per-character config so custom_highlights[*][color|bg_color] --;
    #nop -- get rebaked against the new palette. Save the in-flight theme name first --;
    #nop -- so the char files own theme setting (intended for initial load) doesnt --;
    #nop -- clobber an interactive switch. --;
    #if {"$gstin[config][char_name]" != ""} {
        #script {_charfile_exists} {test -f config/char/$gstin[config][char_name].tin && echo 1 || echo 0};
        #if {"$_charfile_exists[1]" == "1"} {
            #variable {gstin[_reload_theme]} {$gstin[config][theme]};
            #variable {gstin[custom_highlights]} {};
            #read {config/char/$gstin[config][char_name].tin};
            #variable {gstin[config][theme]} {$gstin[_reload_theme]};
        };
    };
    gstin_apply_highlights;
    gstin_apply_combat;
    gstin_apply_substitutes;
    #variable {gstin[_prev][header]}     {0};
    #variable {gstin[_prev][body]}       {_};
    #variable {gstin[_prev][vitals]}     {_};
    #variable {gstin[_prev][mind]}       {_};
    #variable {gstin[_prev][enc]}        {_};
    #variable {gstin[_prev][conditions]} {_};
    #variable {gstin[_prev][spell]}      {_};
    #variable {gstin[_prev][hands]}      {_};
    #variable {gstin[_prev][bottom]}     {_};
    #variable {gstin[_chat_dirty]} {1};
    #nop -- Rewrap chat/familiar against new theme: their raw buffers hold --;
    #nop -- theme-neutral placeholder form, so rewrap re-resolves colors. --;
    #nop -- Room placeholders resolve via gstin_prepare_room_info on render. --;
    gstin_chat_rewrap;
    gstin_familiar_rewrap;
    gstin_dirty_all;
    gstin_request_render;
}

#nop -- Theme selection: `theme <name>` switches directly. `theme` alone shows --;
#nop -- the menu of available names. Picking from the menu is done by typing --;
#nop -- `theme <name>` on a subsequent line -- we do not try to eat a bare number --;
#nop -- because no path involving alias or event dispatch has reliably stopped --;
#nop -- that number from reaching write_mud in testing. --;
#alias {theme} {
    #local {_name} {%1};
    #if {"$_name" != ""} {
        #variable {gstin[config][theme]} {$_name};
        gstin_load_theme;
        #showme {$gstin[colors][system][status]--- Theme: $gstin[config][theme]<099>};
        #return;
    };
    #showme {};
    #showme {$gstin[colors][system][status]--- Available themes ---<099>};
    #showme {  catdark     catlight};
    #showme {  everdark    everlight};
    #showme {  gruvdark    gruvlight};
    #showme {  icedark     icelight};
    #showme {  seouldark   seoullight};
    #showme {};
    #showme {Current: $gstin[config][theme]};
    #showme {$gstin[colors][system][status]--- Use: theme <name> ---<099>};
}

#nop -- Toggle raw XML logging to /tmp/gstin_raw.log --;
#alias {gstin_rawlog} {
    #math {gstin[rawlog]} {!$gstin[rawlog]};
    #if {$gstin[rawlog] == 1} {
        #showme {$gstin[colors][system][status]--- Raw logging: ON (/tmp/gstin_raw.log)<099>};
    } {
        #showme {$gstin[colors][system][status]--- Raw logging: OFF<099>};
    };
}

#nop -- Toggle spacing debug log to /tmp/gstin_space.log --;
#alias {gstin_spacelog} {
    #math {gstin[_spacelog]} {!$gstin[_spacelog]};
    #if {$gstin[_spacelog] == 1} {
        #showme {$gstin[colors][system][status]--- Space logging: ON (/tmp/gstin_space.log)<099>};
    } {
        #showme {$gstin[colors][system][status]--- Space logging: OFF<099>};
    };
}

#nop -- Force redraw status area --;
#alias {gstin_redraw} {
    gstin_dirty_all;
    gstin_render_all;
    #showme {$gstin[colors][system][status]--- UI redrawn<099>};
}

#nop -- Toggle familiar panel (Ctrl+L) --;
#macro {\x0c} {
    #if {$gstin[familiar][active] == 1} {
        #variable {gstin[_familiar_hidden]} {1};
        gstin_hide_familiar_panel;
    } {
        #variable {gstin[_familiar_hidden]} {0};
        gstin_show_familiar_panel;
    };
}

#nop -- Toggle spells sidebar (Ctrl+S) --;
#macro {\x13} {
    #if {$gstin[ui][right_active] == 1} {
        #variable {gstin[ui][right_disabled]} {1};
        gstin_effects_stop_ticker;
        gstin_hide_right_sidebar;
        #showme {$gstin[colors][system][status]--- Spells sidebar: OFF<099>};
    } {
        #variable {gstin[ui][right_disabled]} {0};
        gstin_show_right_sidebar;
        gstin_effects_start_ticker;
        #showme {$gstin[colors][system][status]--- Spells sidebar: ON<099>};
    };
}

#class {gstin_macros} {close}
